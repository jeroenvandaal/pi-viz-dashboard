[Unit]
Description=Viz Dashboard server
After=network-online.target

[Service]
WorkingDirectory=%h/pi-dashboard
Environment=VIZ_DB=%h/pi-dashboard/dashboard.db
EnvironmentFile=%h/.config/viz-dashboard.env
ExecStart=%h/pi-dashboard/server/.venv/bin/python -m uvicorn server.app:app --host 0.0.0.0 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
